# Django
DEBUG=True
SECRET_KEY=dev-insecure-change-me-in-production
ALLOWED_HOSTS=*

# CORS — origins allowed to call the API (the Vite SPA)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Postgres (matches docker-compose service "db")
POSTGRES_DB=vidora
POSTGRES_USER=vidora
POSTGRES_PASSWORD=vidora
POSTGRES_HOST=db
POSTGRES_PORT=5432

# JWT lifetimes
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7

# One-time code (email OTP) time-to-live, minutes
OTP_TTL_MINUTES=10

# Email — leave EMAIL_HOST blank to print codes to the console (dev).
# For Gmail, EMAIL_HOST_PASSWORD must be a 16-char App Password, not your login password.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_TIMEOUT=15
DEFAULT_FROM_EMAIL=Vidora <no-reply@vidora.local>

# --- AI providers ---
ANTHROPIC_API_KEY=
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_SECRET=
# Prompton chat model (claude-sonnet-4-6 default; claude-haiku-4-5 for lower cost)
PROMPTON_MODEL=claude-sonnet-4-6
